{
  "name": "@pixies/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src"
  },
  "dependencies": {
    "@pixies/core": "workspace:*",
    "@earendil-works/pi-agent-core": "0.79.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0"
  }
}
