{
  "name": "@pixies/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./db": {
      "types": "./src/db/index.ts",
      "default": "./src/db/index.ts"
    },
    "./logging": {
      "types": "./src/logging/index.ts",
      "default": "./src/logging/index.ts"
    },
    "./logging/posthog-logs-sink": {
      "types": "./src/logging/posthog-logs-sink.ts",
      "default": "./src/logging/posthog-logs-sink.ts"
    }
  },
  "scripts": {
    "typecheck": "tsgo",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "test": "bun test"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.79.3",
    "@earendil-works/pi-ai": "0.79.3",
    "@logtape/logtape": "^2.1.1",
    "@logtape/otel": "^2.1.1",
    "better-result": "^2.9.2",
    "drizzle-orm": "^0.45.2",
    "lru-cache": "^11.2.1",
    "p-queue": "^9.3.0",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "better-sqlite3": "^12.11.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0"
  }
}
