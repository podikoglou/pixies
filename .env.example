# AI provider — required. Format: "provider/model-id" (e.g. "openai/gpt-4o")
PIXIES_MODEL=

# API key for the AI provider — required
PIXIES_API_KEY=

# Email for Let's Encrypt SSL certificates (Caddy) — required for production
# CADDY_EMAIL=

# Contact email included in OSM API requests (optional)
# PIXIES_CONTACT_EMAIL=

# Custom Overpass API URL (default: https://overpass-api.de/api/interpreter)
# PIXIES_OVERPASS_URL=

# Custom Nominatim API URL (default: https://nominatim.openstreetmap.org)
# PIXIES_NOMINATIM_URL=

# User-Agent header for OSM requests (default: Pixies)
# PIXIES_USER_AGENT=

# Server listen hostname (default: 127.0.0.1)
PIXIES_HOST=0.0.0.0

# Server listen port (default: 3000)
# PIXIES_PORT=3000

# AI thinking level: off|low|medium|high (default: off)
# PIXIES_THINKING_LEVEL=

# Path to SQLite database file (default: pixies.db)
# PIXIES_DB_FILE=

# Max in-memory conversation cache size (default: 50)
# PIXIES_CACHE_SIZE=
