# AI provider — required. Format: "provider/model-id" (e.g. "openai/gpt-4o")
PIXIES_MODEL=

# API key for the AI provider — required
PIXIES_API_KEY=

# Domain for Caddy reverse proxy (required for production TLS)
# DOMAIN=

# Email for Let's Encrypt SSL certificates (Caddy) — required for production
# CADDY_EMAIL=

# Contact email included in OSM API requests (optional)
# PIXIES_CONTACT_EMAIL=

# Custom Overpass API URL (default: https://overpass-api.de/api/interpreter)
# PIXIES_OVERPASS_URL=

# Max concurrent in-flight Overpass requests (default: 2; the public overpass-api.de policy)
# PIXIES_OVERPASS_CONCURRENCY=

# Max Overpass requests started per interval window (default: 2)
# PIXIES_OVERPASS_INTERVAL_CAP=

# Overpass interval window length in ms (default: 1000)
# PIXIES_OVERPASS_INTERVAL_MS=

# Custom Nominatim API URL (default: https://nominatim.openstreetmap.org)
# PIXIES_NOMINATIM_URL=

# Max concurrent in-flight Nominatim requests (default: 1; the public nominatim.openstreetmap.org policy)
# PIXIES_NOMINATIM_CONCURRENCY=

# Max Nominatim requests started per interval window (default: 1)
# PIXIES_NOMINATIM_INTERVAL_CAP=

# Nominatim interval window length in ms (default: 1100 → ~1 req/s)
# PIXIES_NOMINATIM_INTERVAL_MS=

# TTL for cached Nominatim search/reverse responses in ms (default: 86400000 = 24h; 0 disables).
# Recommended by the Nominatim usage policy. Cache hits skip the network and the rate-limit queue.
# PIXIES_NOMINATIM_CACHE_TTL_MS=

# Max cached Nominatim responses before LRU eviction (default: 1000; 0 disables caching)
# PIXIES_NOMINATIM_CACHE_MAX_ENTRIES=

# User-Agent header for OSM requests (default: Pixies/1.0 (https://github.com/podikoglou/pixies))
# PIXIES_USER_AGENT=

# Server listen hostname (default: 127.0.0.1)
PIXIES_HOST=0.0.0.0

# Server listen port (default: 3000)
# PIXIES_PORT=3000

# AI thinking level: off|low|medium|high (default: off)
# PIXIES_THINKING_LEVEL=

# Path to SQLite database file (default: pixies.db)
# PIXIES_DB_FILE=

# Max in-memory conversation cache size (default: 50)
# PIXIES_CACHE_SIZE=

# Max POST requests per IP per window on the LLM-cost endpoints (default: 30; 0 disables)
# PIXIES_HTTP_RATE_LIMIT=

# Per-IP HTTP rate-limit window length in ms (default: 60000)
# PIXIES_HTTP_RATE_LIMIT_WINDOW_MS=

# Honor X-Forwarded-For for client IP — set true behind Caddy/Nginx (default: false)
# PIXIES_TRUST_PROXY=

# Number of rightmost trusted XFF hops for IP spoofing prevention (default: 1)
# PIXIES_TRUSTED_PROXY_HOPS=

# Max tokens (input + output) a single conversation may consume across all turns
# (default: 0 = unlimited). Useful to control costs — once the budget is
# exhausted, further messages are rejected with a 403 response.
# PIXIES_CONVERSATION_TOKEN_BUDGET=

# Discord webhook URL for error/fatal log alerts (optional). When unset, errors
# are logged to stdout only.
# PIXIES_DISCORD_WEBHOOK_URL=

# ----------------------------------------------------------------------------
# PostHog (web SPA) — optional and OFF BY DEFAULT. No telemetry leaves the
# browser unless you set VITE_POSTHOG_KEY. These are read by Vite; the web
# build only exposes vars prefixed with VITE_. See docs/posthog-privacy.md.
# ----------------------------------------------------------------------------

# PostHog PUBLIC project token (safe to ship to the browser — NOT the secret
# server API key). Leave unset to keep telemetry off.
# VITE_POSTHOG_KEY=

# PostHog Cloud host for your project region, e.g. https://eu.i.posthog.com or
# https://us.i.posthog.com (defaults to https://app.posthog.com if unset).
# VITE_POSTHOG_HOST=
