# Base URL of the Pixies instance under test.
PIXIES_EVAL_BASE_URL=https://pixies.aleep.lol

# Per-request timeout (ms). Agent turns do multiple OSM round-trips + retries.
PIXIES_EVAL_TIMEOUT_MS=120000

# Judge credentials. promptfoo's llm-rubric uses the grader provider set in
# promptfooconfig.yaml (default: openrouter:google/gemini-3.1-flash-lite), which
# needs OPENROUTER_API_KEY. Swap the `grader` in config for a stronger judge if
# you see false passes (e.g. openrouter:anthropic/claude-3.5-sonnet).
OPENROUTER_API_KEY=sk-or-...
